# OBRIGATÓRIO — chave secreta para assinar os tokens JWT
SECRET_KEY=coloque_sua_chave_secreta_aqui

# Caminho para o banco de dados SQLite (padrão: usuarios.db na raiz)
DB_PATH=usuarios.db

# ==============================================
# THRESHOLDS DE CONFIANÇA DA IA
# ==============================================
# Abaixo disso → WARNING. Padrão: 75
PASS_THRESHOLD=75

# Abaixo disso → WARNING (revisão manual). Padrão: 50
WARN_THRESHOLD=50

# Abaixo disso → WARNING independente da classe. Padrão: 40
CONF_THRESHOLD=40
